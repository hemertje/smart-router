# 🚀 Smart Router Daily Check Environment Configuration

# Email Configuration (Gmail SMTP)
SMTP_USER=jouw.email@gmail.com
SMTP_PASS=jouw_app_password

# Recipient Email
RECIPIENT_EMAIL=jouw.email@gmail.com

# Smart Router Configuration
SMART_ROUTER_API_KEY=your_openrouter_api_key
SMART_ROUTER_BASE_URL=https://openrouter.ai/api/v1

# Monitoring Configuration
MONITORING_INTERVAL=3600000
LOG_LEVEL=info

# Performance Tracking
ENABLE_PERFORMANCE_METRICS=true
ENABLE_INTELLIGENCE_GAPS_ANALYSIS=true

# Scheduling
DAILY_CHECK_TIME=09:00
TIMEZONE=Europe/Amsterdam

# Development (set to false for production)
DEBUG_MODE=false
TEST_MODE=false
