# 🚀 Smart Router - Cursor MacBook Ultimate Environment
# Configureer deze variabelen voor de ultieme vibe coding experience

# 📡 Server Configuration
CURSOR_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# 🤖 AI Model API Keys
# Anthropic Claude models
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI models (GPT-4, Vision)
OPENAI_API_KEY=sk-...

# Google Gemini models
GOOGLE_API_KEY=...

# 🎸 Vibe Coding Settings
VIBE_MODE=flow
FLOW_STATE_THRESHOLD=0.8
CREATIVE_ENHANCEMENT=true
AI_PARTNERSHIP_MODE=collaborative

# 🍎 MacBook M5 Optimizations
M5_OPTIMIZATION=true
ARM64_NATIVE=true
PERFORMANCE_MODE=maximum
THERMAL_MANAGEMENT=auto
BATTERY_OPTIMIZATION=true

# 📊 Performance Settings
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30000
CACHE_ENABLED=true
CACHE_TTL=300

# 💰 Cost Optimization
COST_TRACKING=true
BUDGET_LIMIT=0.10
COST_ALERTS=true
SAVINGS_TARGET=0.40

# 🔍 Monitoring & Analytics
PERFORMANCE_MONITORING=true
FLOW_STATE_TRACKING=true
USER_BEHAVIOR_ANALYSIS=true
REAL_TIME_METRICS=true

# 🎯 Model Selection Preferences
DEFAULT_MODEL=cursor-sonnet
AUTOCOMPLETE_MODEL=cursor-haiku
COMPLEX_REASONING_MODEL=cursor-opus
VISION_MODEL=cursor-vision
BULK_PROCESSING_MODEL=cursor-flash

# 📈 Quality Settings
MIN_CONFIDENCE_THRESHOLD=0.7
MAX_RETRIES=3
FALLBACK_ENABLED=true
QUALITY_ASSURANCE=true

# 🌐 Network Settings
RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100
CONNECTION_POOL_SIZE=20
TIMEOUT_MS=30000

# 🔧 Development Settings
DEBUG_MODE=false
VERBOSE_LOGGING=false
HOT_RELOAD=true
AUTO_RESTART=true

# 🎨 UI/UX Settings
THEME=vibe-coding-ultimate
ANIMATIONS=smooth
SOUND_EFFECTS=subtle
DISTRACTION_FREE=true

# 📚 Learning & Adaptation
ADAPTIVE_LEARNING=true
USER_PATTERN_DETECTION=true
PREFERENCE_LEARNING=true
PERFORMANCE_OPTIMIZATION=true

# 🔒 Security & Sandbox Configuration
SECURITY_ENABLED=true
SANDBOX_MODE=true
AUDIT_LOGGING=true
THREAT_DETECTION=true
RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100
REQUEST_TIMEOUT=30000
API_KEY_ENCRYPTION=true

# 🔍 Security Monitoring
SECURITY_LEVEL=high
BLOCK_SUSPICIOUS_REQUESTS=true
VALIDATE_REQUESTS=true
MONITOR_ANOMALIES=true
SECURITY_ALERTS=true

# 🛡️ Sandbox Settings
SANDBOX_ISOLATION=full
SANDBOX_FILE_ACCESS=restricted
SANDBOX_NETWORK_ACCESS=controlled
SANDBOX_RESOURCE_LIMITS=true
SANDBOX_CPU_LIMIT=50
SANDBOX_MEMORY_LIMIT=2048
SANDBOX_DISK_LIMIT=1024

# 🔐 Allowed Domains
ALLOWED_DOMAINS=api.anthropic.com,api.openai.com,generativelanguage.googleapis.com
BLOCKED_DOMAINS=
RESTRICTED_IP_RANGES=

# 📊 Security Metrics
SECURITY_MONITORING=true
AUDIT_LOG_RETENTION_DAYS=30
SECURITY_REPORTING=true
THREAT_INTELLIGENCE=true
COMPLIANCE_CHECKING=true

# 🌟 Advanced Features
PARALLEL_PROCESSING=true
CONTEXT_AWARE_ROUTING=true
PREDICTION_CACHE=true
INTELLIGENT_CACHING=true

# 📊 Customization
USER_ID=your-user-id
SESSION_TIMEOUT=3600
PERSONALIZATION=true
CUSTOM_PROMPTS=true

# 🎯 Cursor Integration
CURSOR_INTEGRATION=true
COMPOSER_MODE_ENHANCED=true
TAB_AUTOCOMPLETE_ENHANCED=true
AI_CHAT_ENHANCED=true

# 🍎 macOS Specific
MACOS_INTEGRATION=true
NOTIFICATIONS=true
SPOTLIGHT_SEARCH=true
KEYCHAIN_ACCESS=true

# 📱 Mobile Support (optional)
MOBILE_SYNC=false
REMOTE_ACCESS=false
CLOUD_BACKUP=false

# 🔄 Backup & Recovery
AUTO_BACKUP=true
BACKUP_INTERVAL=3600
RECOVERY_MODE=true
DATA_INTEGRITY_CHECK=true

# 🎉 Success Metrics
PRODUCTIVITY_TRACKING=true
FLOW_STATE_ANALYSIS=true
CODE_QUALITY_METRICS=true
SATISFACTION_TRACKING=true
